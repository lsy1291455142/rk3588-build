<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <remote name="rockchip"
          fetch="https://github.com/rockchip-linux"
          review="gerrit.rockchip.com" />

  <default remote="rockchip"
           revision="develop-6.6"
           sync-j="4" />

  <!-- ===== 核心组件 ===== -->
  <project name="kernel"    path="kernel"    revision="develop-6.6" />
  <project name="u-boot"    path="u-boot"    revision="next-dev" />
  <project name="rkbin"     path="rkbin"     revision="master" />
  <project name="buildroot" path="buildroot"  revision="master" />
  <project name="docs"      path="docs"      revision="master" />

</manifest>
