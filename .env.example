# Optional defaults for repeated local use.
# Prefer separate use targets:
#   make use-volume            # interactive
#   make use-board             # interactive
#   make use-rootfs            # interactive
#   make use-volume-rock5c     # shortcut
#   make use-board-rock5c      # shortcut
#   make use-rootfs-debian     # shortcut
# Board profile. Required for all component and image builds.
BOARD=rk3588s-rock-5c

# Root filesystem. Required for rootfs and image targets: buildroot, debian, or all.
ROOTFS=buildroot

# Debian release: 11 (bullseye), 12 (bookworm), or 13 (trixie).
DEBIAN_RELEASE=13

# Optional Debian feature sets (comma-separated).
# Tokens: nm, hwdebug, tools, firstboot-info, wifibt, all
# Empty: use board DEBIAN_FEATURES_DEFAULT if set, else minbase.
# Force minbase over board default: DEBIAN_FEATURES=none
# Example: DEBIAN_FEATURES=nm,hwdebug,firstboot-info,wifibt
DEBIAN_FEATURES=

# WiFi/BT firmware for feature wifibt (optional; not needed for wired-only).
# Chip: none|AIC8800D80|AP6275S|AP6256|RTL8822CS|ALL_AP|ALL_CY|ALL
# Source: sdk-or-assets|sdk|assets
# Required: yes fails build if firmware missing; no only warns
WIFIBT_CHIP=
WIFIBT_SOURCE=
WIFIBT_REQUIRED=

# Optional hostname for Debian images (default rk3588; muse profile defaults to muse).
ROOTFS_HOSTNAME=

# Development account created in Buildroot and Debian images.
# Change the password before deploying outside an isolated lab network.
ROOTFS_USERNAME=rk3588
ROOTFS_PASSWORD=rk3588

# Debian mirrors.
DEBIAN_MIRROR=http://deb.debian.org/debian
DEBIAN_SECURITY_MIRROR=http://security.debian.org/debian-security
DEBIAN_ALLOW_ARCHIVE_FALLBACK=yes

# SDK source selection.
# SDK volume: set once here, all make commands inherit it automatically.
# Switch by editing this line, overriding on the command line, or `make use-volume-*`.
# Board is switched separately with `make use-board-*`.
SDK_VOLUME=rk3588-sdk-rock5c
MANIFEST=
CUSTOM_MANIFEST_URL=
CUSTOM_MANIFEST_NAME=
BRANCH=main

# Fetch and build controls.
FETCH_ON_START=no
JOBS=0
DEPTH=1
MAX_RETRIES=3
EXTRA_COMPONENTS=no
CCACHE_MAXSIZE=10G
USE_NATIVE_BUILD=no

# Final .img.zst compression level.
ZSTD_LEVEL=6
