# =============================================================================
# RK3588 Docker 编译环境 - 环境变量配置
# 复制为 .env 后根据需要修改
# =============================================================================

# ---- BSP 源选择 ----
# rockchip   - Rockchip 官方 GitHub (推荐, 最通用)
# firefly    - Firefly AIO-3588 BSP (较完整, 含构建脚本)
# radxa      - Radxa Rock 5B BSP (社区活跃)
# orangepi   - Orange Pi 5 BSP
# custom     - 自定义 manifest URL
BSP_SOURCE=rockchip

# ---- 代码分支 ----
# Rockchip 官方: stable-5.10 / stable-6.1
# Firefly: main / rk3588-linux
# Radxa: main / rock-5b
BRANCH=stable-5.10

# ---- 容器启动时自动拉取源码 ----
# yes - 容器启动时自动执行 fetch_sources.sh
# no  - 需手动在容器内执行 fetch_sources.sh
FETCH_ON_START=no

# ---- 编译并行数 ----
# 0 = 自动检测 CPU 核数
JOBS=0

# ---- Git 克隆深度 ----
# 1 = 浅克隆 (最快, 适合首次拉取)
# 0 = 完整克隆 (适合需要 git history 的场景)
DEPTH=1

# ---- 额外组件 ----
# yes = 拉取 device-tree / debian 等额外仓库
# no  = 仅拉取核心组件 (kernel / u-boot / rkbin / buildroot)
EXTRA_COMPONENTS=no

# ---- 自定义 Manifest (BSP_SOURCE=custom 时生效) ----
CUSTOM_MANIFEST_URL=
CUSTOM_MANIFEST_NAME=default.xml

# ---- ccache 配置 ----
CCACHE_MAXSIZE=10G

# ---- Docker 资源限制 ----
DOCKER_CPUS=8
DOCKER_MEMORY=16G
