# Kernel capabilities required by the optional read-only overlay rootfs mode
# (ROOTFS_MODE=ro-overlay): a SquashFS lower layer combined with an OverlayFS
# upper layer plus an initramfs that assembles them before switch_root.
#
# These options are always merged into the kernel so a single common kernel
# artifact can boot both rw-ext4 and ro-overlay images. They are inert for
# rw-ext4 images (never exercised) and add only a few KiB to the Image.
CONFIG_BLK_DEV_INITRD=y
CONFIG_RD_GZIP=y
CONFIG_RD_ZSTD=y
CONFIG_SQUASHFS=y
CONFIG_SQUASHFS_FILE_DIRECT=y
CONFIG_SQUASHFS_DECOMP_MULTI=y
CONFIG_SQUASHFS_XATTR=y
CONFIG_SQUASHFS_ZLIB=y
CONFIG_SQUASHFS_LZ4=y
CONFIG_SQUASHFS_LZO=y
CONFIG_SQUASHFS_XZ=y
CONFIG_SQUASHFS_ZSTD=y
CONFIG_OVERLAY_FS=y
CONFIG_OVERLAY_FS_REDIRECT_DIR=y
CONFIG_OVERLAY_FS_INDEX=y
