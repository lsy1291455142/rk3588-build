# 用户环境配置
.env

# 日志
*.log

# 编辑器
*.swp
*.swo
*~
.vscode/
.idea/

# macOS
.DS_Store

# 编译产物 (如果在宿主机编译)
output/
out/

# Python bytecode
__pycache__/
*.pyc

# Board-local WiFi/BT firmware blobs (CokePi AIC; large binaries not in git)
# Staged by board plugin during build-rootfs (or optional stage-aic8800-firmware.sh)
boards/*/rootfs/packages/**
!boards/*/rootfs/packages/**/
!boards/*/rootfs/packages/.gitkeep
boards/*/rootfs/overlay/lib/firmware/**
!boards/*/rootfs/overlay/lib/firmware/**
!boards/*/rootfs/overlay/lib/firmware/**/SOURCE.txt
# Legacy assets path (ignore blobs; keep markers)
assets/wifibt/**
!assets/wifibt/**/
!assets/wifibt/.gitkeep
!assets/wifibt/**/SOURCE.txt

