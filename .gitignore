# WiFi/BT firmware blobs (optional overlay; legacy assets path still ignored)
# Preferred: rootfs/debian/overlays/wifibt/firmware/
rootfs/debian/overlays/wifibt/firmware/**
!rootfs/debian/overlays/wifibt/firmware/**/
!rootfs/debian/overlays/wifibt/firmware/.gitkeep
!rootfs/debian/overlays/wifibt/firmware/**/SOURCE.txt
# Legacy fallback path
# Ignore blob files, but keep directory markers and SOURCE.txt provenance notes.
assets/wifibt/**
!assets/wifibt/**/
!assets/wifibt/.gitkeep
!assets/wifibt/**/SOURCE.txt

