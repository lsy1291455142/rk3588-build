# 用户环境配置
.env

# 日志
*.log

# 编辑器
*.swp
*.swo
*~
.vscode/
.idea/

# macOS
.DS_Store

# 编译产物 (如果在宿主机编译)
output/
out/

# Board-local WiFi/BT firmware blobs (CokePi AIC; large binaries not in git)
# Stage with: rootfs/debian/boards/rk3588s-cokepi-model-lp4-v10/stage-aic8800-firmware.sh
rootfs/debian/boards/*/packages/**
!rootfs/debian/boards/*/packages/**/
!rootfs/debian/boards/*/packages/.gitkeep
rootfs/debian/boards/*/overlay/lib/firmware/**
!rootfs/debian/boards/*/overlay/lib/firmware/**/
!rootfs/debian/boards/*/overlay/lib/firmware/**/SOURCE.txt
# Legacy assets path (ignore blobs; keep markers)
assets/wifibt/**
!assets/wifibt/**/
!assets/wifibt/.gitkeep
!assets/wifibt/**/SOURCE.txt

